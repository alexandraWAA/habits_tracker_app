[flake8]
max-line-length = 127
max-complexity = 10
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    migrations,
    build,
    dist,
    *.egg,
    .eggs
ignore =
    E203,
    W503,
    E501
per-file-ignores =
    */migrations/*: E501
    */__init__.py: F401
count = true
statistics = true
show-source = true